# Port on which the backend server will run
PORT=5000

# MongoDB connection string
# Where to get: Create a cluster on MongoDB Atlas (https://cloud.mongodb.com/) and get the connection string, or use local MongoDB (e.g., mongodb://localhost:27017/ecommerce)
MONGO_URI=your_mongodb_connection_string

# Secret key for JWT authentication
# Where to get: Any random strong string (e.g., generate using `openssl rand -base64 32`)
JWT_SECRET=your_jwt_secret_key

# Cloudinary configuration (used for image/file uploads)
# Where to get: Sign up or log in to Cloudinary (https://cloudinary.com/) and copy these from the Dashboard console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe configuration (used for payment gateway integration)
# Where to get: Sign up or log in to Stripe (https://stripe.com/) and go to Developers -> API Keys (use test keys for development)
STRIPE_SECRET_KEY=your_stripe_secret_key
# Where to get: From Stripe Dashboard Webhooks settings or Stripe CLI when running `stripe listen` command locally
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Email Service (Brevo - formerly Sendinblue)
# Where to get: Sign up or log in to Brevo (https://www.brevo.com/) -> SMTP & API section to generate an API key
BREVO_API_KEY=your_brevo_api_key
# Where to get: The verified sender email address set up in your Brevo account
BREVO_SENDER_EMAIL=your_verified_sender_email
# API endpoint for sending emails (Brevo SMTP API)
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# URL of the frontend application (for CORS and redirects)
FRONTEND_URL=http://localhost:5173


# Firebase Admin SDK (for Google Auth token verification)
# Where to get: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
