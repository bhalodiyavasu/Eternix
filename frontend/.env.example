# Backend API Base URL
# Where to get: The URL of the running backend server. For local development, this is typically http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# Default Admin Credentials
# Where to get: The email of the admin account registered or seeded in your database
VITE_ADMIN_EMAIL=admin@gmail.com
# Where to get: The password of the admin account registered or seeded in your database
VITE_ADMIN_PASSWORD=admin1234

# Firebase (Google Auth)
# Where to get: Firebase Console > Project Settings > Your Apps > Web App > SDK setup and configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
# Where to get: Same as above — typically your_project_id.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
# Where to get: Same as above — the Firebase project ID
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
